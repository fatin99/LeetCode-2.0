import heapq
from collections import Counter

class Solution:
    # O(nlogn): count the frequency of each number and then sort the array 
    # based on each element’s frequency. After that, select the top k
    # Somehow this performs faster, probably because python's inbuilt sort is veryvery fast
    def topKFrequent(self, nums: List[int], k: int) -> List[int]:
        numCount = Counter(nums)
        sortedNumCount = sorted(numCount.items(), key=lambda item: item[1], reverse=True)
        topK = []
        i = 0
        while k > 0:
            topK.append(sortedNumCount[i][0])
            i += 1
            k -= 1
        return topK
    
    #Bucket Sort (O(n))
    def topKFrequent(self, nums: List[int], k: int) -> List[int]:
        bucket = [[] for _ in range(len(nums) + 1)]
        numCount = Counter(nums)
        for num, count in numCount.items():
            bucket[count].append(num)
        result = []
        while k > 0:
            if bucket[-1]:
                result.extend(bucket[-1])
                k -= len(bucket[-1])
                bucket.pop()
            else:
                bucket.pop()
        return result

