class Solution:
    def findMin(self, nums: List[int]) -> int:
        start = 0
        end = len(nums) - 1
        if nums[start] < nums[end]:
            return start
        while start < end:
            i = int((start+end) / 2)
            curr = nums[i]
            if curr < nums[i-1]:
                return i
            left = nums[start]
            right = nums[end]
            if curr >= left and curr >= right:
                start = i + 1
            else:
                end = i
        if end == len(nums) - 1:
            return end

    def binarySearch(self, nums: List[int], target: int) -> int:
        start = 0
        end = len(nums) - 1
        if not nums:
            return -1
        if nums[start] == target:
            return start
        if nums[end] == target:
            return end
        while start < end:
            index = int((start + end) / 2)
            if nums[index] > target:
                end = index
            if nums[index] < target:
                start = index + 1
            if nums[index] == target:
                return index
        return -1
    
