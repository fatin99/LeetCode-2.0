    def search(self, nums: List[int], target: int) -> int:
        start = 0
        end = len(nums) - 1
        while start <= end:
            i = int((start+end) / 2)
            mid= nums[i]
            if mid == target:
                return i
            left = nums[start]
            if left == target:
                return start
            right = nums[end]
            if right == target:
                return right
            if left <= mid:
                if target > mid or target < left:
                    start = i+1
                else:
                    end = i
            else:
                if target < mid or target > right:
                    end = i
                else:
                    start = i+1
        return -1
        
